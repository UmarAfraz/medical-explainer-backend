# Medical Report Explanation System - Environment Variables
# Copy this file to .env and fill in your actual values

# ========================================
# REQUIRED SETTINGS
# ========================================

# OpenAI API Key (REQUIRED)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ========================================
# OPTIONAL SETTINGS
# ========================================

# Flask Environment (development, production, testing)
FLASK_ENV=development

# Flask Secret Key (generate a random string for production)
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=5000

# OpenAI Model Configuration
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# File Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_FOLDER=temp_uploads

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Caching (future feature)
ENABLE_CACHE=False
CACHE_TIMEOUT=3600

# ========================================
# NOTES
# ========================================
# - Never commit .env file to version control
# - Keep your API keys secret
# - Use strong SECRET_KEY in production
# - For production, set FLASK_ENV=production
